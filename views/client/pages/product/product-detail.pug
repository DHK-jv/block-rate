extends ../../layouts/default

block content
  .pd-page


    //- ── HERO SECTION ──
    .pd-hero
      .pd-hero__img
        img(src=product.image, alt=product.name, onerror="this.src='https://placehold.co/800x600/0a0e1a/94a3b8?text=No+Image'")
      
      .pd-hero__info
        .pd-id ID: #{product._id}
        h1.pd-title= product.name
        
        .pd-badge-group.d-flex.gap-2.mb-2
          span.badge.bg-primary.bg-opacity-10.text-primary.rounded-pill.px-3= product.category.toUpperCase()
          if product.brand
            span.badge.bg-white.bg-opacity-10.text-white.text-opacity-75.rounded-pill.px-3= product.brand

        .pd-price
          span.pd-price__current= product.price.toLocaleString('vi-VN') + 'đ'
          if product.oldPrice
            span.pd-price__original= product.oldPrice.toLocaleString('vi-VN') + 'đ'
          else
            span.pd-price__original (Giá niêm yết)

        blockquote.pd-desc= product.description

        //- Buy Section
        #buySection.mt-3
          button.pd-cta#btnMuaHang(data-id=product._id.toString())
            span.material-symbols-outlined shopping_cart
            | Mua hàng ngay
        
        p.pd-cta-note.fs-9.mt-2
          span.material-symbols-outlined.fs-9.me-1 security
          | Giao dịch được bảo mật và lưu trữ trên Blockchain

    //- ── REVIEWS SECTION ──
    .pd-reviews
      //- Review Form Panel
      .pd-reviews__form
        h3.mb-4 Gửi đánh giá
        
        //- Review Gate (locked state)
        #reviewGate.pd-review-gate
          span.material-symbols-outlined.mb-3(style="font-size:48px; opacity:0.2") lock
          p.pd-review-gate__title Quyền đánh giá bị khóa
          p#reviewGateMsg.pd-review-gate__msg Đang xác thực quyền truy cập...

        //- Review Form (hidden until unlocked)
        #reviewFormWrapper.d-none
          p.pd-form-label.mb-2 Xếp hạng sản phẩm
          .pd-stars.mb-3#starRating
            - for (let i = 1; i <= 5; i++)
              span.material-symbols-outlined.star-btn(data-value=i) star
          input#ratingValue(type="hidden" value="0")
          
          p.pd-form-label.mb-2 Nhận xét của bạn
          textarea#reviewContent(rows="4" placeholder="Sản phẩm dùng rất tốt, giao hàng nhanh...")
          
          #reviewAlert.alert.alert-danger.rounded-3.py-2.px-3.fs-7.mt-3.d-none(role="alert")
          
          button#btnGuiDanhGia.pd-form-btn.mt-3
            span.material-symbols-outlined.me-2 send
            | Gửi đánh giá

      //- Reviews List
      .pd-reviews__list
        .pd-reviews__header
          h2.d-flex.align-items-center.gap-2
            span.material-symbols-outlined.text-primary rate_review
            | Đánh giá từ cộng đồng
          if reviews.length == onchainReviewCount
            if reviews.length == 0
              .pd-transparent-badge.bg-light.rounded-3.p-2.text-muted
                 span.material-symbols-outlined.fs-7 info
                 span Sản phẩm chưa có đánh giá nào
            else
              .pd-transparent-badge.bg-success.bg-opacity-10.border.border-success.rounded-3.p-2.d-flex.align-items-center.gap-2.text-success
                span.material-symbols-outlined.fs-6 verified_user
                span Khớp số lượng On-chain (#{reviews.length}/#{onchainReviewCount})
          else if reviews.length < onchainReviewCount
            .alert.alert-danger.rounded-3.p-2.m-0.d-flex.align-items-center.gap-2.border-danger
              span.material-symbols-outlined.fs-6 warning
              strong CẢNH BÁO CHE GIẤU:
              span Chỉ hiển thị #{reviews.length} trên tổng số #{onchainReviewCount} đánh giá gốc!
          else if reviews.length > onchainReviewCount
            .pd-transparent-badge.bg-warning.bg-opacity-10.text-warning.rounded-3.p-2.d-flex.align-items-center.gap-2.mb-2
              span.material-symbols-outlined.fs-6 inventory_2
              span Phát hiện dữ liệu Ảo / Chưa đồng bộ (Hiển thị: #{reviews.length} - Thực tế Blockchain: #{onchainReviewCount})

        each review in reviews
          .pd-review-card
            .pd-review-card__top
              .pd-reviewer  
                .pd-reviewer__avatar= review.user && review.user.walletAddress ? review.user.walletAddress.substring(2, 4).toUpperCase() : '??'
                .pd-reviewer__meta
                  strong= review.user && review.user.walletAddress ? review.user.walletAddress : 'Người dùng ẩn danh'
              
              .pd-review-stars
                - for (let i = 1; i <= 5; i++)
                  span.material-symbols-outlined(style=`font-size:16px; color: ${i <= review.rating ? '#f59e0b' : '#cbd5e1'}`) star

            p.pd-review-card__text= review.content || 'Không có nhận xét nào.'
            
            .pd-review-card__footer.mt-3.pt-3.border-top.d-flex.align-items-center.justify-content-between
              button.pd-verified.verify-btn(
                  data-id=review._id
                  data-tx=review.txHash
                  type="button"
                )
                  span.material-symbols-outlined(style="font-size:16px") account_balance_wallet
                  span Blockchain Verify
              
              .pd-tx
                if review.txHash
                  a.pd-tx-link(
                    href=`https://explorer.cronos.org/testnet/tx/${review.txHash}`
                    target="_blank"
                    rel="noopener noreferrer"
                  )
                    svg(width="14" height="14" viewBox="0 0 24 24" fill="none")
                      path(d="M14 3h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
                      path(d="M10 14L21 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
                      path(d="M21 14v7h-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
                      path(d="M3 10L14 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")

                    span.pd-tx-text.ms-1 #{review.txHash.slice(0, 8)}...#{review.txHash.slice(-6)}

                  button.copy-btn(type="button" data-tx=review.txHash title="Copy TX") 📋
                else
                  span.pd-tx-na Tx: N/A

        a.pd-load-more(href="#")
          span.material-symbols-outlined.me-1(style="vertical-align: middle") expand_more
          | Xem thêm đánh giá

block scripts
  script.
    var productId = "#{product._id}"
    var hasBought = #{hasBought || false}
    var pendingReviewCount = #{pendingReviewCount || 0}

    //- ── Wallet Sync & UI Update ──
    function updateDetailUI() {
      checkReviewAccess();
    }

    // ── Traditional Buy (Server) ──
    var btnMua = document.getElementById('btnMuaHang')
    if (btnMua) {
      btnMua.addEventListener('click', async function() {
        var web3 = window.BlockRateWeb3
        if (!web3 || !web3.isConnected) {
          return showToast('Vui lòng kết nối ví để lưu lịch sử mua hàng on-chain.', 'warning')
        }

        btnMua.disabled = true
        btnMua.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...'
        
        try {
          var res = await fetch('/product/buy/' + productId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          })
          var data = await res.json()
          if (data.success) {
            btnMua.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Đã mua hàng'
            btnMua.classList.add('opacity-50')
            hasBought = true
            pendingReviewCount++
            showToast('Mua hàng thành công! Bạn có thể đánh giá sản phẩm ngay.', 'success')
            checkReviewAccess()
          } else if (res.status === 401) {
            window.location.href = '/login'
          } else {
            showToast(data.message, 'error')
            btnMua.disabled = false
            btnMua.innerHTML = '<span class="material-symbols-outlined">shopping_cart</span> Mua hàng ngay'
          }
        } catch {
          showToast('Lỗi kết nối máy chủ', 'error')
          btnMua.disabled = false
          btnMua.innerHTML = '<span class="material-symbols-outlined">shopping_cart</span> Mua hàng ngay'
        }
      })
    }



    // ── Review Access Gate ──
    async function checkReviewAccess() {
      var gate = document.getElementById('reviewGate')
      var form = document.getElementById('reviewFormWrapper')
      var msg = document.getElementById('reviewGateMsg')
      if (!gate || !form) return

      var web3 = window.BlockRateWeb3
      if (!web3 || !web3.isConnected) {
        gate.classList.remove('d-none')
        form.classList.add('d-none')
        msg.textContent = 'Vui lòng kết nối ví để xác thực quyền đánh giá.'
        return
      }

      if (pendingReviewCount > 0) {
        gate.classList.add('d-none')
        form.classList.remove('d-none')
      } else {
        gate.classList.remove('d-none')
        form.classList.add('d-none')
        msg.textContent = hasBought 
          ? 'Cảm ơn! Bạn đã hoàn thành đánh giá cho lượt mua này.' 
          : 'Bạn chưa mua sản phẩm này. Hãy mua để gửi đánh giá on-chain.'
      }
    }

    // ── Star Rating Interaction ──
    var selectedRating = 0
    var stars = document.querySelectorAll('.star-btn')
    var ratingInput = document.getElementById('ratingValue')

    function renderStars(rating) {
      stars.forEach(function(star) {
        var val = parseInt(star.dataset.value)
        star.style.color = val <= rating ? '#f59e0b' : '#94a3b8'
        star.style.fontVariationSettings = val <= rating ? "'FILL' 1" : "'FILL' 0"
      })
    }

    stars.forEach(function(star) {
      star.addEventListener('mouseover', function() { renderStars(parseInt(star.dataset.value)) })
      star.addEventListener('mouseleave', function() { renderStars(selectedRating) })
      star.addEventListener('click', function() {
        selectedRating = parseInt(star.dataset.value)
        ratingInput.value = selectedRating
        renderStars(selectedRating)
      })
    })

    // ── Submit Review ──
    var btnSubmit = document.getElementById('btnGuiDanhGia')
    if (btnSubmit) {
      btnSubmit.addEventListener('click', async function() {
        var content = document.getElementById('reviewContent').value.trim()
        var rating = parseInt(ratingInput.value)

        if (rating === 0) return showToast('Vui lòng xếp hạng sản phẩm này!', 'warning')
        if (!content || content.length < 5) return showToast('Nhận xét quá ngắn hoặc để trống!', 'warning')

        btnSubmit.disabled = true
        btnSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Đang gửi...'
        
        try {
          var res = await fetch('/product/review/' + productId, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rating: rating, content: content })
          })
          var data = await res.json()
          if (data.success) {
            pendingReviewCount--
            appendReviewToDOM(data.review, data.txHash)
            checkReviewAccess()
            document.getElementById('reviewContent').value = ''
            showToast('Đánh giá của bạn đã được lưu on-chain!', 'success')
          } else {
             showToast(data.message, 'error')
          }
        } catch {
          showToast('Lỗi kết nối', 'error')
        } finally {
          btnSubmit.disabled = false
          btnSubmit.innerHTML = '<span class="material-symbols-outlined me-2">send</span> Gửi đánh giá'
        }
      })
    }

    // ── Blockchain Verify Delegation ──
    document.querySelector('.pd-reviews__list')?.addEventListener('click', async function(e) {
      var btn = e.target.closest('.verify-btn')
      if (!btn) return
      
      const label = btn.querySelector('span:not(.material-symbols-outlined)')
      const icon = btn.querySelector('.material-symbols-outlined')
      
      btn.disabled = true
      label.textContent = 'Đang kiểm tra...'
      icon.textContent = 'published_with_changes'
      icon.classList.add('spin-icon')

      try {
        var res = await fetch('/product/verify-review/' + btn.dataset.id)
        var data = await res.json()
        if (data.success) {
          label.textContent = 'Đã xác minh'
          icon.textContent = 'verified'
          btn.style.borderColor = '#22c55e'
          btn.style.color = '#22c55e'
        } else {
          label.textContent = 'Dữ liệu bị sửa đổi'
          icon.textContent = 'report'
          btn.style.borderColor = '#ef4444'
          btn.style.color = '#ef4444'
        }
      } catch {
        label.textContent = 'Lỗi hệ thống'
      }
    })
    
    // ── Copy TxHash Logic ──
    document.querySelector('.pd-reviews__list')?.addEventListener('click', function(e) {
      var btn = e.target.closest('.copy-btn')
      if (!btn) return
      
      var tx = btn.dataset.tx
      if (!tx) return

      navigator.clipboard.writeText(tx).then(() => {
        var originalLabel = btn.textContent
        btn.textContent = '✅'
        btn.title = 'Đã copy!'
        setTimeout(() => {
          btn.textContent = originalLabel
          btn.title = 'Copy TX'
        }, 2000)
        showToast('Đã copy mã giao dịch vào bộ nhớ tạm', 'success')
      }).catch(err => {
        console.error('Lỗi khi copy:', err)
        showToast('Không thể copy tự động', 'error')
      })
    })

    function appendReviewToDOM(review, txHash) {
       location.reload() // Simplify for now to ensure all styles match
    }

    // ── Init ──
    window.addEventListener('DOMContentLoaded', updateDetailUI)
    window.addEventListener('walletUIUpdated', updateDetailUI)