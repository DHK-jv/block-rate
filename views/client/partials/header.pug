//- Styles moved to style.css or consolidated below (only interactive logic kept here if any)

script.


  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('d-none')
    })
  }

  // ── Wallet Connect ──
  function updateWalletUI(info) {
    const elements = [
      { btn: 'walletBtn', dot: 'walletDot', label: 'walletLabel' },
      { btn: 'walletBtnMobile', dot: 'walletDotMobile', label: 'walletLabelMobile' },
    ]
    elements.forEach(({ btn, label }) => {
      const btnEl = document.getElementById(btn)
      const labelEl = document.getElementById(label)
      if (!btnEl || !labelEl) return
      if (info && info.address) {
        btnEl.classList.add('connected')
        labelEl.textContent = info.shortAddress || BlockRateWeb3.formatAddress(info.address)
        btnEl.title = info.address
      } else {
        btnEl.classList.remove('connected')
        labelEl.textContent = 'Kết nối ví'
        btnEl.title = ''
      }
    })
    window.dispatchEvent(new CustomEvent('walletUIUpdated', { detail: info }))
  }

  async function handleWalletClick() {
    if (!window.BlockRateWeb3) return alert('Module web3 chưa sẵn sàng.')
    if (!window.ethereum) return alert('Vui lòng cài MetaMask tại metamask.io')
    if (BlockRateWeb3.isConnected) {
      BlockRateWeb3.disconnectWallet()
      updateWalletUI(null)
    } else {
      try {
        const info = await BlockRateWeb3.connectWallet()
        updateWalletUI(info)
      } catch (err) {
        alert(err.message)
      }
    }
  }

  document.getElementById('walletBtn')?.addEventListener('click', handleWalletClick)
  document.getElementById('walletBtnMobile')?.addEventListener('click', handleWalletClick)

  // Restore wallet on page load
  window.addEventListener('DOMContentLoaded', async () => {
    if (window.BlockRateWeb3 && window.ethereum) {
      try {
        const info = await BlockRateWeb3.restoreWallet()
        if (info) updateWalletUI(info)
      } catch {}
    }
  })

  // Listen for MetaMask events
  window.addEventListener('walletChanged', (e) => updateWalletUI(e.detail))
  window.addEventListener('walletDisconnected', () => updateWalletUI(null))